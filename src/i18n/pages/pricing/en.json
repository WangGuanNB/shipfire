  "faq": {
    "name": "faq",
    "label": "FAQ",
    "title": "Frequently Asked Questions",
    "description": "Get answers to common questions about our subscription plans.",
    "items": [
      {"title": "Why subscribe?", "description": "Your support helps us keep improving the product, and you get valuable benefits: watermark-free outputs, priority queue, faster generation, full privacy, and ad-free experience."},
      {"title": "Can I upgrade or cancel?", "description": "Anytime! You can upgrade or cancel in one click from your account settings page. Your subscription runs through the end of your billing term, with no long-term contract."},
      {"title": "Can I get a refund?", "description": "We currently do not offer refunds. Please review the plan details before purchasing. For exceptional cases, contact support@shipfire.app."},
      {"title": "Do I get higher quality with paid plans?", "description": "Yes. Standard and Premium unlock more features and benefits, including priority queue, watermark-free outputs, commercial use rights, and more."},
      {"title": "Does my subscription include API access?", "description": "We don't have a public API at the moment but plan to offer one in the future. Feel free to reach out at support@shipfire.app with your requirements."},
      {"title": "Can I get help using the product?", "description": "Yes! Contact us at support@shipfire.app. Paid users receive priority technical support, and we'll respond as quickly as possible."}
    ]
  }
